---
// ⬇️ REEMPLAZÁ por tu link de Calendly cuando lo tengas (o dejá #contacto)
const AGENDA = "https://calendly.com/bermudezdamian7/30min";

const servicios = [
  {
    titulo: "Asistente con IA 24/7",
    subtitulo: "Tu negocio responde solo",
    descripcion:
      "Un agente que atiende a tus clientes por WhatsApp y en tu web: responde las consultas de siempre, agenda turnos y filtra los contactos que valen la pena.",
    incluye: [
      "Respuestas automáticas a preguntas frecuentes",
      "Agenda de turnos o reservas",
      "Derivación a vos cuando hace falta",
    ],
    resultado: "Dejá de perder ventas fuera de horario.",
  },
  {
    titulo: "Automatización de tareas",
    subtitulo: "El trabajo aburrido, hecho solo",
    descripcion:
      "Conecto las herramientas que ya usás para que las tareas repetitivas se hagan solas: recordatorios, presupuestos, carga de datos y seguimientos por mail o WhatsApp.",
    incluye: [
      "Recordatorios y seguimientos automáticos",
      "Conexión entre tus apps (formularios, planillas, mail)",
      "Reportes sin que muevas un dedo",
    ],
    resultado: "Recuperá horas cada semana.",
  },
  {
    titulo: "Web que trae clientes",
    subtitulo: "Una web que trabaja, no que decora",
    descripcion:
      "Un sitio rápido y profesional pensado para captar contactos y convertirlos en clientes, conectado a tus automatizaciones para que ningún lead se pierda.",
    incluye: [
      "Diseño a medida, rápido y mobile-first",
      "Formularios que cargan los datos solos",
      "Integrado con tu asistente y automatizaciones",
    ],
    resultado: "Que tu web te traiga trabajo, no solo likes.",
  },
];
---

<section id="servicios" class="mt-10 border-t border-Background-linea">
  <div class="w-full mx-auto lg:w-[1000px] my-14">
    <h2 class="mt-10 mb-2 text-lg text-Violet-text">Qué hago por tu negocio</h2>
    <h3 class="mb-4 text-4xl md:text-5xl text-Color-titulo">Servicios</h3>
    <p class="max-w-2xl mb-12 text-lg text-Color-parrafo">
      Soluciones simples para problemas concretos. Cada servicio se cobra con
      una <span class="text-Color-titulo"
        >instalación inicial + una mensualidad</span
      >
      para que todo siga funcionando y mejorando.
    </p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        servicios.map((s) => (
          <article class="flex flex-col h-full p-6 transition-all duration-300 border border-Violet-background rounded-2xl hover:bg-Background-icon">
            <h4 class="text-2xl font-semibold text-Color-titulo">{s.titulo}</h4>
            <span class="mb-4 text-sm text-Violet-text">{s.subtitulo}</span>

            <p class="mb-5 text-sm leading-relaxed text-Color-parrafo">
              {s.descripcion}
            </p>

            <ul class="flex flex-col gap-2 mb-6">
              {s.incluye.map((item) => (
                <li class="flex items-start gap-2 text-sm text-Color-parrafo">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#a476ff"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="shrink-0 mt-0.5"
                  >
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>

            <p class="mt-auto mb-4 text-sm font-medium text-Color-titulo">
              {s.resultado}
            </p>

            <a
              href={AGENDA}
              class="px-4 py-2 text-center transition-all duration-300 border text-Color-titulo border-Violet-background rounded-xl hover:bg-Violet-background"
            >
              Lo quiero
            </a>
          </article>
        ))
      }
    </div>

    <div class="flex justify-center mt-12">
      <a
        href={AGENDA}
        class="px-8 py-3 text-lg transition-all duration-300 border text-Color-titulo bg-Violet-background border-Violet-background rounded-xl hover:opacity-80"
      >
        ¿No sabés qué necesitás? Agendá un diagnóstico gratis
      </a>
    </div>
  </div>
</section>
