---
import { Image } from "astro:assets";
import ecommerce from "../assets/ecommerce.png";
import mercedesmichelini from "../assets/mercedes.png";
import perfilplac from "../assets/perfilplac.png";
import redsocial from "../assets/redsocial.png";

// ───────────────────────────────────────────────────────────────
// Para sumar un caso nuevo (automatización / IA), copiá un objeto
// de abajo y completá los campos. Campos opcionales: resultado,
// repo, demo (si no los ponés, simplemente no se muestran).
//
//   {
//     nombre: "Automatización de turnos para consultorio",
//     categoria: "Automatización",
//     imagen: miImagen,                 // import miImagen from "../assets/..."
//     alt: "Captura del flujo en n8n",
//     descripcion: "Flujo en n8n que toma las reservas y las agenda solo.",
//     resultado: "Ahorro de 8 hs semanales en gestión manual.",
//     tags: ["n8n", "Google Calendar", "WhatsApp"],
//     demo: "",                          // opcional
//     repo: "",                          // opcional
//   },
// ───────────────────────────────────────────────────────────────

const proyectos = [
  {
    nombre: "E-commerce",
    categoria: "Desarrollo web",
    imagen: ecommerce,
    alt: "Proyecto E-commerce",
    descripcion:
      "Tienda online con catálogo de productos, carrito de compras, autenticación de usuarios y panel de administración.",
    resultado: "",
    tags: ["React", "Node.js", "MongoDB"],
    demo: "https://desafio-final-mod10.vercel.app/",
    repo: "https://github.com/DamianBermudez94/desafio-final-mod10",
  },
  {
    nombre: "Red Social",
    categoria: "Desarrollo web",
    imagen: redsocial,
    alt: "Proyecto Red Social",
    descripcion:
      "Red social con registro de usuarios, publicaciones y feed dinámico, conectada a una API REST propia.",
    resultado: "",
    tags: ["React", "API REST"],
    demo: "https://frond-end-red-social.vercel.app/",
    repo: "https://github.com/DamianBermudez94/frond-end-red-social",
  },
  {
    nombre: "Perfil-Plac",
    categoria: "Diseño web",
    imagen: perfilplac,
    alt: "Landing page Perfil-Plac",
    descripcion:
      "Landing page para una empresa de placas de yeso, pensada para presentar los productos y captar consultas de clientes.",
    resultado: "",
    tags: ["Astro", "TailwindCSS"],
    demo: "https://perfil-plac.com/",
    repo: "https://github.com/DamianBermudez94/Perfil-Plac",
  },
  {
    nombre: "Michelini Mercedes",
    categoria: "Diseño web",
    imagen: mercedesmichelini,
    alt: "Sitio web inmobiliaria Michelini Mercedes",
    descripcion:
      "Sitio web institucional para una inmobiliaria, con presentación de propiedades y contacto directo.",
    resultado: "",
    tags: ["Astro", "TailwindCSS"],
    demo: "https://www.michelinimercedes.com/",
    repo: "https://github.com/DamianBermudez94/mercedes-michelini",
  },
];
---

<section id="proyectos" class="mt-10 border-t border-Background-linea">
  <div class="w-full mx-auto lg:w-[1000px] my-14">
    <h2 class="mt-10 mb-2 text-lg text-Violet-text">Mis trabajos</h2>
    <h3 class="mb-4 text-4xl md:text-5xl text-Color-titulo">
      Casos y proyectos
    </h3>
    <p class="max-w-2xl mb-12 text-lg text-Color-parrafo">
      Algunos de los trabajos que hice. Pronto sumo casos de automatización y
      asistentes con IA.
    </p>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        proyectos.map((p) => (
          <article class="flex flex-col h-full overflow-hidden transition-all duration-300 border border-Violet-background rounded-2xl hover:bg-Background-icon">
            <div class="overflow-hidden">
              <Image
                src={p.imagen}
                alt={p.alt}
                class="object-cover w-full h-48 transition-all duration-300 hover:scale-105"
              />
            </div>

            <div class="flex flex-col p-5 grow">
              <span class="self-start text-xs text-Violet-text border border-Violet-background rounded-full px-3 py-0.5 mb-3">
                {p.categoria}
              </span>

              <h4 class="mb-2 text-2xl font-semibold text-Color-titulo">
                {p.nombre}
              </h4>

              <p class="mb-4 text-sm leading-relaxed text-Color-parrafo">
                {p.descripcion}
              </p>

              {p.resultado && (
                <div class="flex items-start gap-2 mb-4">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#a476ff"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="shrink-0 mt-0.5"
                  >
                    <path d="m22 7-8.5 8.5-5-5L2 17" />
                    <path d="M16 7h6v6" />
                  </svg>
                  <span class="text-sm font-medium text-Color-titulo">
                    {p.resultado}
                  </span>
                </div>
              )}

              <div class="flex flex-wrap gap-2 mb-5">
                {p.tags.map((tag) => (
                  <span class="text-xs text-Color-parrafo border border-Violet-background rounded-full px-2 py-0.5">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="flex gap-3 mt-auto">
                {p.demo && (
                  <a
                    href={p.demo}
                    target="_blank"
                    class="flex items-center gap-2 px-4 py-2 text-sm transition-all duration-300 border rounded-lg text-Color-titulo border-Violet-background hover:bg-Violet-background"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M15 3h6v6" />
                      <path d="M10 14 21 3" />
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    </svg>
                    Ver sitio
                  </a>
                )}
                {p.repo && (
                  <a
                    href={p.repo}
                    target="_blank"
                    class="flex items-center gap-2 px-4 py-2 text-sm transition-all duration-300 border rounded-lg text-Color-parrafo border-Violet-background hover:bg-Background-icon"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                      <path d="M9 18c-4.51 2-5-2-7-2" />
                    </svg>
                    Código
                  </a>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <a
      href="https://github.com/DamianBermudez94"
      target="_blank"
      class="flex justify-center gap-3 p-3 mt-10 text-lg transition-all border rounded-full text-Color-parrafo border-Violet-background hover:bg-Background-icon"
    >
      Más proyectos en
      <span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path>
          <path d="M9 18c-4.51 2-5-2-7-2"></path>
        </svg>
      </span>
    </a>
  </div>
</section>
