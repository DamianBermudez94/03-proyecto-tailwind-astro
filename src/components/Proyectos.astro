---
import { Image } from "astro:assets";
import ecommerce from "../assets/ecommerce.png";
import mercedesmichelini from "../assets/mercedes.png";
import perfilplac from "../assets/perfilplac.png";
import redsocial from "../assets/redsocial.png";
import iconCode from "../../public/svg/code-white.svg";
import iconNavigation from "../../public/svg/navigation-white.svg";
---

<section id="proyectos" class="mt-10 border-t border-Background-linea">
  <div class="w-full mx-auto lg:w-[1000px] my-14">
    <h2 class="mt-10 mb-2 text-lg text-Violet-text">Mis trabajos</h2>
    <h3 class="mb-8 text-5xl text-Color-titulo">Proyectos</h3>
    <div class="">
      <div class="grid grid-cols-1 gap-10 pt-10 mt-10 md:grid-cols-2">
        <article>
          <div class="flex justify-center cursor-pointer">
            <Image
              src={ecommerce}
              alt="Proyecto Ecommerce"
              class="w-full h-48 max-w-md transition-all duration-300 hover:scale-110"
            />
          </div>

          <div class="flex justify-center p-3 mt-5">
            <div>
              <h4 class="text-2xl font-semibold text-Color-titulo">
                Desarrollador
              </h4>
              <span class="py-1 text-sm text-Color-parrafo">E-commerce</span>
              <div class="flex flex-wrap gap-2 mt-2">
                <span
                  class="text-xs text-Color-parrafo border border-Violet-background rounded-full px-2 py-0.5"
                  >React</span
                >
                <span
                  class="text-xs text-Color-parrafo border border-Violet-background rounded-full px-2 py-0.5"
                  >Node.js</span
                >
                <span
                  class="text-xs text-Color-parrafo border border-Violet-background rounded-full px-2 py-0.5"
                  >MongoDB</span
                >
              </div>
            </div>

            <div class="flex gap-2 ml-auto">
              <a
                href="https://github.com/DamianBermudez94/desafio-final-mod10"
                target="_blank"
                class="p-2 transition-all border rounded-md border-Violet-background hover:bg-Background-icon"
              >
                <Image
                  src={iconCode}
                  alt="E-commerce ProyectoWeb"
                  class="w-9 h-9"
                />
              </a>
              <a
                href="https://desafio-final-mod10.vercel.app/"
                target="_blank"
                class="p-2 transition-all border rounded-md border-Violet-background hover:bg-Background-icon"
              >
                <Image
                  src={iconNavigation}
                  alt="E-commerce ProyectoWeb"
                  class="w-9 h-9"
                />
              </a>
            </div>
          </div>
        </article>
        <article>
          <div class="flex justify-center cursor-pointer">
            <Image
              src={redsocial}
              alt="Proyecto Red social"
              class="w-full h-48 max-w-md transition-all duration-300 shadow-md hover:scale-110"
            />
          </div>

          <div class="flex items-center p-3 mt-5">
            <div>
              <h4 class="text-2xl font-semibold text-Color-titulo">
                Desarrollador
              </h4>
              <span class="py-1 text-sm text-Color-parrafo"> Red Social </span>
              <div class="flex flex-wrap gap-2 mt-2">
                <span
                  class="text-xs text-Color-parrafo border border-Violet-background rounded-full px-2 py-0.5"
                  >React</span
                >
                <span
                  class="text-xs text-Color-parrafo border border-Violet-background rounded-full px-2 py-0.5"
                  >API REST</span
                >
              </div>
            </div>

            <div class="flex gap-2 ml-auto">
              <a
                href="https://github.com/DamianBermudez94/frond-end-red-social"
                target="_blank"
                class="p-2 transition-all border rounded-md border-Violet-background hover:bg-Background-icon"
              >
                <Image
                  src={iconCode}
                  alt="RedSocial ProyectoWeb"
                  class="w-9 h-9"
                />
              </a>
              <a
                href="https://frond-end-red-social.vercel.app/"
                target="_blank"
                class="p-2 transition-all border rounded-md border-Violet-background hover:bg-Background-icon"
              >
                <Image
                  src={iconNavigation}
                  alt="RedSocial ProyectoWeb"
                  class="w-9 h-9"
                />
              </a>
            </div>
          </div>
        </article>
        <article>
          <div class="flex justify-center cursor-pointer">
            <Image
              src={perfilplac}
              alt="Proyecto Landing page"
              class="w-full h-48 max-w-md transition-all duration-300 shadow-md hover:scale-110"
            />
          </div>

          <div class="flex items-center p-3 mt-5">
            <div>
              <h4 class="text-2xl font-semibold text-Color-titulo">
                Diseñador
              </h4>
              <span class="py-1 text-sm text-Color-parrafo">Landing Page</span>
              <div class="flex flex-wrap gap-2 mt-2">
                <span
                  class="text-xs text-Color-parrafo border border-Violet-background rounded-full px-2 py-0.5"
                  >Astro</span
                >
                <span
                  class="text-xs text-Color-parrafo border border-Violet-background rounded-full px-2 py-0.5"
                  >TailwindCSS</span
                >
              </div>
            </div>

            <div class="flex gap-2 ml-auto">
              <a
                href="https://perfil-plac.com/"
                target="_blank"
                class="p-2 transition-all border rounded-md border-Violet-background hover:bg-Background-icon"
              >
                <Image
                  src={iconNavigation}
                  alt="landingPage DiseñoWeb"
                  class="w-9 h-9"
                />
              </a>
              <a
                href="https://github.com/DamianBermudez94/Perfil-Plac"
                target="_blank"
                class="p-2 transition-all border rounded-md border-Violet-background hover:bg-Background-icon"
              >
                <Image
                  src={iconCode}
                  alt="landingPage DiseñoWeb"
                  class="w-9 h-9"
                />
              </a>
            </div>
          </div>
        </article>
        <article>
          <div class="flex justify-center cursor-pointer">
            <Image
              src={mercedesmichelini}
              alt="Proyecto Negocios Inmobiliaria"
              class="w-full h-48 max-w-md transition-all duration-300 shadow-md hover:scale-110"
            />
          </div>

          <div class="flex items-center p-3 mt-5">
            <div>
              <h4 class="text-2xl font-semibold text-Color-titulo">
                Diseñador
              </h4>
              <span class="py-1 text-sm text-Color-parrafo"> Sitio Web </span>
              <div class="flex flex-wrap gap-2 mt-2">
                <spa
                  class="text-xs text-Color-parrafo border border-Violet-background rounded-full px-2 py-0.5"
                  >Astro</spa
                >
                <span
                  class="text-xs text-Color-parrafo border border-Violet-background rounded-full px-2 py-0.5"
                  >TailwindCSS</span
                >
              </div>
            </div>

            <div class="flex gap-2 ml-auto">
              <a
                href="https://www.michelinimercedes.com/"
                target="_blank"
                class="p-2 transition-all border rounded-md border-Violet-background hover:bg-Background-icon"
              >
                <Image
                  src={iconNavigation}
                  alt="inmobiliaria Sitio Web"
                  class="w-9 h-9"
                />
              </a>
              <a
                href="https://github.com/DamianBermudez94/mercedes-michelini"
                class="p-2 transition-all border rounded-md border-Violet-background hover:bg-Background-icon"
              >
                <Image
                  src={iconCode}
                  alt="inmobiliaria SitioWeb"
                  class="w-9 h-9"
                />
              </a>
            </div>
          </div>
        </article>
      </div>
    </div>
    <a
      href="https://github.com/DamianBermudez94"
      target="_blank"
      class="flex justify-center gap-3 p-2 mt-8 text-xl transition-all border rounded-full text-Color-parrafo border-Violet-background hover:bg-Background-icon"
      >Más proyectos en <span
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-github"
          ><path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
        ></span
      >
    </a>
  </div>
</section>
