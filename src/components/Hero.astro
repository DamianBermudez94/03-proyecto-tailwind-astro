---
import LogoWall from "../utils/Carrusel.astro";

// ⬇️ REEMPLAZÁ estos dos valores por los tuyos:
const WHATSAPP = "https://wa.me/542227508824"; // tu número con código de país (54 9 ...)
const AGENDA = "https://calendly.com/bermudezdamian7/30min"; // cuando tengas Calendly, poné acá tu link (ej: https://calendly.com/tu-usuario)
---

<section id="inicio" class="w-full mx-auto lg:w-[1000px] pt-20 md:pt-40">
  <p class="mb-4 text-sm tracking-wide uppercase text-Violet-text md:text-base">
    Webs · Automatización · Agentes de IA
  </p>

  <h1
    class="max-w-3xl text-4xl font-bold leading-tight md:text-6xl text-Color-titulo"
  >
    Que tu negocio no pierda clientes
    <span class="text-Violet-text">aunque vos no estés</span>
  </h1>

  <p
    class="max-w-2xl my-8 text-lg leading-relaxed text-Color-parrafo md:text-2xl"
  >
    Soy <span class="text-Color-titulo">Damián Bermúdez</span>. Ayudo a
    comercios y PyMEs de Lobos y la zona a vender más y trabajar menos: sitios
    web y asistentes con IA que
    <span class="text-Color-titulo">atienden, responden y agendan por vos</span
    >, las 24 horas.
  </p>

  <div class="flex flex-col gap-4 mb-6 sm:flex-row">
    <a
      href={AGENDA}
      target="_blank"
      class="px-6 py-3 text-lg text-center transition-all duration-300 border text-Color-titulo bg-Violet-background border-Violet-background rounded-xl hover:opacity-80"
    >
      Agendá una llamada gratis
    </a>
    <a
      href={WHATSAPP}
      target="_blank"
      class="flex items-center justify-center gap-2 px-6 py-3 text-lg transition-all duration-300 border text-Color-titulo border-Violet-background rounded-xl hover:bg-Background-icon"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
      </svg>
      Escribime por WhatsApp
    </a>
  </div>

  <p class="mb-10 text-sm text-Color-parrafo">
    Sin compromiso · Te muestro qué se puede automatizar en tu negocio.
  </p>

  <!-- Redes / CV (secundario) -->
  <div class="flex flex-wrap items-center gap-3 my-5">
    <a
      href="https://github.com/DamianBermudez94"
      target="_blank"
      aria-label="GitHub"
      class="flex items-center justify-center w-12 h-12 transition duration-300 border border-Violet-background rounded-xl text-Color-icon hover:bg-Background-icon"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path
          d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
        ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
      >
    </a>
    <a
      href="https://www.linkedin.com/in/damianbermudezdeveloper/"
      target="_blank"
      aria-label="LinkedIn"
      class="flex items-center justify-center w-12 h-12 transition duration-300 border border-Violet-background rounded-xl text-Color-icon hover:bg-Background-icon"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path
          d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
        ></path><rect width="4" height="12" x="2" y="9"></rect><circle
          cx="4"
          cy="4"
          r="2"></circle></svg
      >
    </a>
    <a
      href="/CV-Damian-Bermudez-2026.pdf"
      target="_blank"
      download="CVDamianBermudez.pdf"
      class="flex items-center h-12 px-5 transition duration-300 border text-Color-icon border-Violet-background rounded-xl hover:bg-Background-icon hover:text-Color-titulo"
    >
      Descargar CV
    </a>
  </div>

  <LogoWall />
</section>
